<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
    <addon id="repository.sabri-maranan" name="Sabri Maranan Repository" version="1.0.0" provider-name="motekamazon-droid">
        <extension point="xbmc.addon.repository" name="Sabri Maranan Repository">
            <dir minversion="18.0">
                <info compressed="false">https://raw.githubusercontent.com/motekamazon-droid/repo/main/addons.xml</info>
                <checksum>https://raw.githubusercontent.com/motekamazon-droid/repo/main/addons.xml.md5</checksum>
                <datadir zip="true">https://raw.githubusercontent.com/motekamazon-droid/repo/main/zips</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>Repository for Sabri Maranan subtitles and addons</summary>
            <description>Official repository for Sabri Maranan English subtitles addon and related tools</description>
            <disclaimer>For use with Kodi media center</disclaimer>
            <language></language>
            <platform>all</platform>
            <license>GPL-2.0</license>
            <website>https://github.com/motekamazon-droid/repo</website>
            <source>https://github.com/motekamazon-droid/repo</source>
        </extension>
    </addon>
    <addon id="plugin.subtitles.sabri-maranan" name="Sabri Maranan" version="1.2.0" provider-name="motekamazon-droid">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
        </requires>
        <extension point="xbmc.subtitle.module" library="main.py"/>
        <extension point="xbmc.addon.metadata">
            <summary>English subtitles for Sabri Maranan from GitHub</summary>
            <description>Subtitle service for downloading English subtitles for Sabri Maranan episodes directly from GitHub. Select this service when downloading subtitles during playback.</description>
            <disclaimer>Requires internet access to fetch subtitles from GitHub</disclaimer>
            <language>en</language>
            <platform>all</platform>
            <license>GPL-2.0</license>
            <website>https://github.com/motekamazon-droid/repo</website>
            <source>https://github.com/motekamazon-droid/repo</source>
        </extension>
    </addon>
</addons>
