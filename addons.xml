<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
    <addon id="service.sabri-maranan-subtitles" name="Sabri Maranan Subtitles" version="1.0.0" provider-name="motekamazon-droid">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
        </requires>
        <extension point="xbmc.service" library="service.py"/>
        <extension point="xbmc.addon.metadata">
            <summary>Auto-fetch English subtitles for Sabri Maranan from GitHub</summary>
            <description>Automatically downloads and applies English subtitles for Sabri Maranan episodes from a public GitHub repository. When you play a Sabri Maranan episode, the addon will extract the episode number and fetch the matching subtitle file from GitHub.</description>
            <disclaimer>This addon requires internet access to fetch subtitles from GitHub.</disclaimer>
            <language></language>
            <platform>all</platform>
            <license>GPL-2.0</license>
            <website>https://github.com/motekamazon-droid/repo</website>
            <source>https://github.com/motekamazon-droid/repo</source>
            <assets>
            </assets>
        </extension>
    </addon>
    <addon id="repository.sabri-maranan" name="Sabri Maranan Repository" version="1.0.0" provider-name="motekamazon-droid">
        <extension point="xbmc.addon.repository" name="Sabri Maranan Repository">
            <dir minversion="2.0.0">
                <info compressed="false">https://raw.githubusercontent.com/motekamazon-droid/repo/main/addons.xml</info>
                <checksum>https://raw.githubusercontent.com/motekamazon-droid/repo/main/addons.xml.md5</checksum>
                <datadir zip="true">https://raw.githubusercontent.com/motekamazon-droid/repo/main/zips</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>Repository for Sabri Maranan addons</summary>
            <description>This repository contains the Sabri Maranan English subtitles addon</description>
            <disclaimer>For use with Kodi media center</disclaimer>
            <language></language>
            <platform>all</platform>
            <license>GPL-2.0</license>
            <website>https://github.com/motekamazon-droid/repo</website>
            <source>https://github.com/motekamazon-droid/repo</source>
            <assets>
            </assets>
        </extension>
    </addon>
</addons>
